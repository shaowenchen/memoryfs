# MemoryFS cluster environment (copy to .env)
MEMORYFS_IMAGE=shaowenchen/memoryfs:latest
MEMORYFS_REPLICA_FACTOR=2
MEMORYFS_CHUNK_BACKEND=tiered
MEMORYFS_MEM_CACHE_MB=512
MEMORYFS_DISK_QUOTA_GB=100
MEMORYFS_GC_INTERVAL=5m
MEMORYFS_FLUSH_INTERVAL=30s
MEMORYFS_DEFAULT_TTL=0
MEMORYFS_MAX_FILE_AGE=0
MEMORYFS_URI_PREFIX=/memoryfs
